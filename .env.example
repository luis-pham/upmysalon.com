NEXT_PUBLIC_SITE_URL=https://upmysalon.com
# Alias kept for older scripts; prefer NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_SERVER_URL=https://upmysalon.com

# Google Tag Manager container ID (from tagmanager.google.com)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Payload CMS (see docs/01-setup.md + docs/06-deploy.md) ───────────────────
# Required for /admin:
# Prefer pooler :6543 on Vercel. Append SSL flags for pg v8+/Supabase, e.g.:
# ...postgres?uselibpqcompat=true&sslmode=require
DATABASE_URI=
# DATABASE_URI_DIRECT=          # Supabase direct :5432 (migrations in prod)
PAYLOAD_SECRET=
# PAYLOAD_DATABASE_PUSH=true    # optional: force schema push (dev default on)
#
# Cloudflare R2 media (docs/06-deploy.md). When all set, uploads go to R2; else local /media.
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=upmysalon-media
R2_PUBLIC_URL=https://cdn.upmysalon.com
S3_REGION=auto

# ── Live demo call (RingBooker partner) ──────────────────────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC (must not ship to the browser).
DEMO_PARTNER_KEY=
# Origin RingBooker allowlisted for this site (sent by the server proxy).
DEMO_PARTNER_ORIGIN=https://upmysalon.com
# RingBooker public demo session mint endpoint.
RINGBOOKER_DEMO_SESSION_URL=https://ringbooker.com/api/backend/public/demo/realtime-session

# Browser (safe to expose): same Turnstile widget as RingBooker after adding
# hostname upmysalon.com in the Cloudflare Turnstile dashboard.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Must be direct_openai for browser mic → OpenAI Realtime WebRTC.
NEXT_PUBLIC_DEMO_WEB_CALL_MODE=direct_openai